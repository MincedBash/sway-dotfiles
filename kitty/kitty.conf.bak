enable_audio_bell no
window_alert_on_bell no
remember_window_size no
initial_window_width  935
initial_window_height 615
# tab_bar_background #ffffff
cursor_trail 1
shell_integration no-cursor
cursor_shape underline
cursor_underline_thickness 0.2
# cursor_trail_color #ffca4d

#Fonts
# font_family FiraCode Nerd Font
font_family JetBrains Mono
bold_font auto
italic_font auto
bold_italic_font auto
font_size 13

# url
detect_urls yes
# url_color #ffff00
url_style straight
open_url_with default

# Theme
# background #1b1b27
# selection_background #ffffff
# dynamic_background_opacity yes
# active_border_color #7AA2F7
# inactive_border_color #000000

# window padding
window_margin_width 8

# tabs
tab_bar_edge top
tab_bar_margin_width 1.0
tab_bar_margin_height 1.0 0.5
tab_bar_style powerline
tab_powerline_style slanted
tab_title_template "{index}"
hide_window_decorations no 

# styling tabs
# active_tab_foreground #0da38a 
# active_tab_background #1d202f
active_tab_font_style bold-italic
# inactive_tab_foreground #ffffff
# inactive_tab_background #292945
inactive_tab_font_style normal

# clipboard
map ctrl+shift+c copy_to_clipboard
map ctrl+shift+v paste_from_clipboard

# keymaps
map ctrl+shift+i next_layout
map ctrl+enter new_window
map ctrl+shift+l next_window
map ctrl+shift+h previous_window
map ctrl+t new_tab
map ctrl+shift+w close_tab
map ctrl+shift+r load_config_file
map f11 toggle_fullscreen
map ctrl+super+enter toggle_fullscreen



# BEGIN_KITTY_THEME
# Brogrammer
include current-theme.conf
# END_KITTY_THEME
#include eldritch.conf
# Decay
#include decay.conf

# include oxocarbon.conf
