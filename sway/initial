# Set Aliases
set $term kitty
set $menu "rofi -show drun"

# Launch Binds
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym f10 exec swaylock
bindsym $mod+alt+l exec swaylock
bindsym Shift+F1 exec grim -g "$(slurp)" - | wl-copy
bindsym Shift+f2 exec grim - | wl-copy
bindsym $mod+z border toggle
bindsym $mod+o output eDP-1 disable toggle
bindsym $mod+tab exec "rofi -show run"
bindsym $mod+ctrl+alt+return exec "systemctl suspend"

#Other Configurations
bar swaybar_command waybar
seat seat0 hide_cursor when-typing enable

# Border Configuration
smart_borders on
default_border pixel 2
default_floating_border pixel 2
